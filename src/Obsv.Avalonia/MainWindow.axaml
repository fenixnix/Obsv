<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:AvaloniaEdit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Obsv.Avalonia.MainWindow"
        Title="Obsv.Avalonia - File Reader"
        Width="1024" Height="768"
        Background="#FF1E1E1E">

    <Grid RowDefinitions="Auto,*">
        <!-- Menu Bar -->
        <Menu Grid.Row="0" Background="#FF2D2D2D">
            <MenuItem Header="_File">
                <MenuItem Header="_Open Folder..." Click="OpenFolder_Click" InputGesture="Ctrl+O"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Zoom _In" InputGesture="Ctrl+OemPlus"/>
                <MenuItem Header="Zoom _Out" InputGesture="Ctrl+OemMinus"/>
                <MenuItem Header="_Reset Zoom" InputGesture="Ctrl+D0"/>
            </MenuItem>
            <MenuItem Header="_Theme">
                <MenuItem Header="Dark" Click="ThemeDark_Click"/>
                <MenuItem Header="Light" Click="ThemeLight_Click"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="About Obsv.Avalonia" Click="About_Click"/>
                <MenuItem Header="Keyboard Shortcuts"/>
            </MenuItem>
        </Menu>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" ColumnDefinitions="240,5,*">
            <!-- Sidebar -->
            <Border Grid.Column="0" Background="#FF2D2D2D" BorderBrush="#FF3F3F3F" BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Header -->
                    <Border DockPanel.Dock="Top" Background="#FF252525" Padding="8" BorderBrush="#FF3F3F3F" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="📂" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Open" FontWeight="Bold" Foreground="#FF00FF00" VerticalAlignment="Center" PointerPressed="OpenFolder_Click" Cursor="Hand"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Current Path -->
                    <Border DockPanel.Dock="Top" Background="#FF252525" Padding="4" BorderBrush="#FF3F3F3F" BorderThickness="0,0,0,1">
                        <TextBlock x:Name="CurrentPathText" Text="No folder opened" Foreground="#FF888888" FontSize="11" TextTrimming="CharacterEllipsis"/>
                    </Border>
                    
                    <!-- File List -->
                    <ScrollViewer>
                        <StackPanel x:Name="SidebarContent" Margin="4">
                            <TextBlock Text="Use File > Open Folder to browse" Foreground="#FF666666" FontStyle="Italic" HorizontalAlignment="Center" Margin="10"/>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Resizer -->
            <Border Grid.Column="1" Background="#FF3F3F3F" PointerPressed="Resize_PointerPressed"/>

            <!-- Editor Area -->
            <Border Grid.Column="2" Background="#FF1E1E1E">
                <DockPanel LastChildFill="True">
                    <!-- Editor Toolbar -->
                    <Border DockPanel.Dock="Top" Background="#FF2D2D2D" BorderBrush="#FF3F3F3F" BorderThickness="0,0,0,1" Padding="8,4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock x:Name="FileNameText" Text="No file selected" Foreground="#FF888888" FontWeight="Bold" VerticalAlignment="Center"/>
                            <ToggleButton x:Name="WrapToggle" Content="Wrap" IsChecked="True" Click="WrapToggle_Click" Background="#FF1E1E1E" Foreground="#FF888888" BorderBrush="#FF3F3F3F"/>
                        </StackPanel>
                    </Border>

                    <!-- File Content - AvaloniaEdit -->
                    <Grid>
                        <AvaloniaEdit:TextEditor x:Name="EditorContent"
                                           FontFamily="Consolas"
                                           FontSize="14"
                                           ShowLineNumbers="True"
                                           IsReadOnly="True"
                                           WordWrap="True"
                                           HorizontalScrollBarVisibility="Auto"
                                           VerticalScrollBarVisibility="Auto"/>
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
